# Copy to .env on the VPS (never commit the real .env). Used by docker-compose.yml.

# The real domain Caddy gets a cert for and passkeys are bound to.
DOMAIN=finance.example.com
RP_ID=finance.example.com
RP_NAME="Household Finance OS"
ORIGIN=https://finance.example.com

# Cloudflare R2 (or any S3-compatible store) for Litestream continuous backup.
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_BUCKET=baez-finance-os-backups
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
