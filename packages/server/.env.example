# HTTP
PORT=3000

# WebAuthn / passkeys
# rpID must be the bare domain (no scheme, no port) the passkey is bound to.
# In production this is your real domain (e.g. finance.example.com); "localhost" for local dev.
RP_ID=localhost
RP_NAME="Household Finance OS"
# origin must be the exact scheme+host+port the browser sees.
ORIGIN=http://localhost:5173

# Storage
DB_PATH=./data/app.db

# Set to "true" once served over HTTPS (production) so session + challenge cookies get Secure.
COOKIE_SECURE=false
